---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { 
	title, 
	description = "Consultor Senior Odoo e Ingeniero de Software. Especialista en lógica financiera, localización fiscal SENIAT y arquitecturas limpias con Python, Flutter y PostgreSQL." 
} = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Open Graph / LinkedIn / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="/og-image.png" />

		<!-- Google Fonts: Inter -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">

		<title>{title}</title>
	</head>
	<body class="bg-slate-950 text-slate-300 antialiased selection:bg-emerald-500/30 selection:text-emerald-200">
		<!-- Capa de fondo decorativa: Gradiente sutil para profundidad -->
		<div class="fixed inset-0 -z-10 h-full w-full bg-slate-950">
			<div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_-20%,rgba(16,185,129,0.07),rgba(255,255,255,0))]"></div>
			<div class="absolute inset-0 bg-[linear-gradient(to_right,#8080800a_1px,transparent_1px),linear-gradient(to_bottom,#8080800a_1px,transparent_1px)] bg-[size:14px_24px]"></div>
		</div>

		<div class="relative mx-auto min-h-screen max-w-7xl overflow-x-hidden px-6 lg:px-8">
			<slot />
		</div>

		<style is:global>
			:root {
				--accent-gradient: linear-gradient(45deg, #10b981, #34d399 30%, #059669 60%);
			}
			body {
				font-family: 'Inter', system-ui, sans-serif;
			}
			/* Personalización de scrollbar para diseño oscuro */
			::-webkit-scrollbar { width: 8px; }
			::-webkit-scrollbar-track { background: #020617; }
			::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 10px; }
			::-webkit-scrollbar-thumb:hover { background: #334155; }
		</style>
	</body>
</html>