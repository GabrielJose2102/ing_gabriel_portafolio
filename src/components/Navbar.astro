---
const navItems = [
  { name: 'Servicios', href: '#servicios' },
  { name: 'Proyectos', href: '#proyectos' },
  { name: 'Trayectoria', href: '#trayectoria' },
  { name: 'Contacto', href: '#contacto' },
];
---

<nav class="sticky top-0 z-50 w-full border-b border-slate-800/50 bg-slate-950/80 backdrop-blur-md">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo / Nombre -->
      <div class="flex-shrink-0">
        <a href="/" class="group flex items-center space-x-2">
          <div class="h-8 w-8 rounded-lg bg-emerald-500 flex items-center justify-center font-bold text-slate-950 transition-transform group-hover:rotate-12">
            G
          </div>
          <span class="text-xl font-bold tracking-tight text-white">
            Gabriel<span class="text-emerald-500">Torrealba</span>
          </span>
        </a>
      </div>

      <!-- Desktop Menu -->
      <div class="hidden md:block">
        <div class="ml-10 flex items-baseline space-x-8">
          {navItems.map((item) => (
            <a
              href={item.href}
              class="text-sm font-medium text-slate-400 transition-colors hover:text-emerald-400"
            >
              {item.name}
            </a>
          ))}
          <a
            href="https://linkedin.com/in/gabriel-torrealba-1a5059209/"
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-full bg-emerald-500/10 px-4 py-1.5 text-sm font-semibold text-emerald-400 ring-1 ring-inset ring-emerald-500/20 hover:bg-emerald-500/20 transition-all"
          >
            LinkedIn
          </a>
        </div>
      </div>

      <!-- Mobile menu button -->
      <div class="flex md:hidden">
        <button id="mobile-menu-button" type="button" class="inline-flex items-center justify-center rounded-md p-2 text-slate-400 hover:bg-slate-800 hover:text-white focus:outline-none">
          <span class="sr-only">Abrir menú</span>
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-slate-800 bg-slate-950 px-4 py-4 space-y-2">
    {navItems.map((item) => (
      <a
        href={item.href}
        class="block rounded-md px-3 py-2 text-base font-medium text-slate-400 hover:bg-slate-900 hover:text-emerald-400"
      >
        {item.name}
      </a>
    ))}
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>