---
const services = [
  {
    title: "Consultoría & Auditoría Odoo",
    description: "Especialista en implementaciones v17/v18. Auditoría de procesos contables, optimización de servidores y desarrollo de módulos nativos de alta complejidad.",
    icon: "M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0V12a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 12V5.25",
    tags: ["Odoo 18", "Python", "Business Logic"]
  },
  {
    title: "Desarrollo de Software Crítico",
    description: "Diseño de arquitecturas limpias y escalables. Desarrollo móvil con Flutter y backends robustos optimizados para el rendimiento empresarial.",
    icon: "M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5",
    tags: ["Flutter", "Clean Architecture", "Node.js"]
  },
  {
    title: "Especialista Fiscal & Financiero",
    description: "Dominio de localización fiscal SENIAT (Venezuela). Automatización de retenciones, libros legales y gestión multimoneda por lotes.",
    icon: "M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z",
    tags: ["SENIAT", "Multimoneda", "Conciliación"]
  }
];
---

<section id="servicios" class="py-24 border-t border-slate-900">
  <div class="mb-16">
    <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
      Servicios de <span class="text-emerald-500">Ingeniería</span>
    </h2>
    <p class="mt-4 text-lg text-slate-400">
      Soluciones técnicas integrales diseñadas para la optimización de procesos y cumplimiento normativo.
    </p>
  </div>

  <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
    {services.map((service) => (
      <div class="group relative rounded-2xl border border-slate-800 bg-slate-900/40 p-8 transition-all duration-300 hover:-translate-y-2 hover:border-emerald-500/50 hover:bg-slate-900/60">
        <div class="mb-6 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-500/10 text-emerald-500 ring-1 ring-emerald-500/20 group-hover:bg-emerald-500 group-hover:text-slate-950 transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6">
            <path stroke-linecap="round" stroke-linejoin="round" d={service.icon} />
          </svg>
        </div>
        
        <h3 class="mb-3 text-xl font-bold text-white group-hover:text-emerald-400 transition-colors">
          {service.title}
        </h3>
        
        <p class="mb-8 text-sm leading-relaxed text-slate-400">
          {service.description}
        </p>

        <div class="flex flex-wrap gap-2 mt-auto">
          {service.tags.map((tag) => (
            <span class="text-[10px] font-bold uppercase tracking-widest text-emerald-400/80 border border-emerald-500/20 px-2 py-1 rounded bg-emerald-500/5">
              {tag}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>